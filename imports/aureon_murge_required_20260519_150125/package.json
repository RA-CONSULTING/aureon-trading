{
  "name": "codexprosparrow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "runtime:start": "node runtime/server.mjs",
    "desktop:install": "npm --prefix desktop install",
    "desktop:start": "npm --prefix desktop start",
    "desktop:smoke": "npm --prefix desktop run smoke",
    "aureon:cli": "node scripts/aureon_cli.mjs",
    "sandbox:build": "bash scripts/setup_sandbox_runtime.sh",
    "check": "node --check server.mjs && node --check runtime/server.mjs && node --check script.js && bash -n scripts/setup_sandbox_runtime.sh && bash -n scripts/fix_docker_sandbox_access.sh && bash -n scripts/start_aureon_brain_local.sh && bash -n scripts/start_flameborn_runtime.sh",
    "cf:build": "bash scripts/build_workers_assets.sh",
    "cf:dev": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:check": "wrangler whoami"
  },
  "devDependencies": {
    "wrangler": "^4.68.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dockerode": "^5.0.0",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.20.1"
  }
}
