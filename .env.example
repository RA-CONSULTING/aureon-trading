# Copy this file to `.env` and fill in real values locally.
# Do not commit `.env` (this repo is public).

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Alpaca (set ALPACA_PAPER=true if using paper trading keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=false

# Capital.com
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=
CAPITAL_PASSWORD=
CAPITAL_DEMO_MODE=false

# CoinAPI (optional: used for cross-exchange market history/anomaly detection)
COINAPI_KEY=

# ── Aureon Operator switchboard — AI providers (all optional) ─────────────────
# The operator fans a prompt out across whichever of these are set, then grounds
# and collapses the answers through the Aureon repo. With none set it runs fully
# offline on stub/local adapters. See docs/architecture/AUREON_OPERATOR_SWITCHBOARD.md
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Optional self-hosted language cortex (Ollama / vLLM / llama.cpp, OpenAI-compatible)
AUREON_LLM_BASE_URL=
AUREON_LLM_MODEL=

