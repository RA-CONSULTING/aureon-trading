# Copy this file to `.env` and fill in real values locally.
# Do not commit `.env` (this repo is public).

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Alpaca (set ALPACA_PAPER=true if using paper trading keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=false

# Capital.com
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=
CAPITAL_PASSWORD=
CAPITAL_DEMO_MODE=false

# CoinAPI (optional: used for cross-exchange market history/anomaly detection)
COINAPI_KEY=

# ── Data sources (all optional; manage + test them in the Connections UI) ─────
# Market data & macro
COINGECKO_API_KEY=          # optional — CoinGecko works keyless; a key raises limits
FRED_API_KEY=               # macro series (rates, CPI, GDP)
FMP_API_KEY=                # economic / earnings / IPO calendar
# Space & science (NASA feeds fall back to a rate-limited DEMO_KEY if unset)
NASA_API_KEY=               # DONKI solar flares / storms / CMEs, NEO feed
FIRMS_MAP_KEY=              # NASA FIRMS active-wildfire detections
# On-chain & whale flow
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=
ALCHEMY_NETWORK=eth-mainnet
COVALENT_API_KEY=
GLASSNODE_API_KEY=          # paid
UNUSUAL_WHALES_API_KEY=     # paid — options / whale flow
# News & social
WORLD_NEWS_API_KEY=         # news + geopolitical sentiment
# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Aureon Operator switchboard — AI providers (all optional) ─────────────────
# The operator fans a prompt out across whichever of these are set, then grounds
# and collapses the answers through the Aureon repo. With none set it runs fully
# offline on stub/local adapters. See docs/architecture/AUREON_OPERATOR_SWITCHBOARD.md
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ollama / self-hosted language cortex (OpenAI-compatible) ──────────────────
# Setting AUREON_LLM_BASE_URL turns the self-hosted "local" line live on the
# switchboard. Works with Ollama, vLLM, llama.cpp, LocalAI, and Ollama Cloud.
#
#   Local Ollama (on the same machine as the operator):
#     AUREON_LLM_BASE_URL=http://localhost:11434/v1
#     AUREON_LLM_MODEL=llama3.1            # a model you've `ollama pull`ed
#     AUREON_LLM_API_KEY=                  # leave blank — local Ollama needs none
#
#   Ollama Cloud (hosted models at ollama.com):
#     AUREON_LLM_BASE_URL=https://ollama.com/v1
#     AUREON_LLM_MODEL=gpt-oss:120b        # a CLOUD model (llama3.1 is NOT on cloud)
#     AUREON_LLM_API_KEY=<key from https://ollama.com/settings/keys>
#
# NOTE: the Ollama "Device Keys" (ssh-ed25519 …) are PUBLIC keys that just
# register a machine with your account — they are NOT the API key and do not go
# here. Create a real API key at ollama.com/settings/keys for cloud access.
AUREON_LLM_BASE_URL=
AUREON_LLM_MODEL=
AUREON_LLM_API_KEY=

# ── More OpenAI-compatible providers (or set them in the Providers UI) ────────
# The Providers settings page writes these into an encrypted local keystore; you
# can also set them here. Each is key-gated — a line only joins the switchboard
# once its key is present.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
MISTRAL_API_KEY=
MISTRAL_BASE_URL=
GROQ_API_KEY=
GROQ_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=

