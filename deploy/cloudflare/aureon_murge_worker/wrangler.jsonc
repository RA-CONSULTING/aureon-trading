{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codexprosparrow",
  "main": "workers/index.mjs",
  "compatibility_date": "2026-05-13",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist-workers",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
